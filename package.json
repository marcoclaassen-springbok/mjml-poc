{
  "name": "mjml",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prebuild": "mkdirp output",
    "build": "node compile.js",
    "watch": "nodemon --watch . --ext mjml,js --exec \"npm run build\"",
    "serve": "browser-sync start --server \"output\" --files \"output/*.html\" --no-ssi --reload-delay 500 --reload-debounce 500",
    "dev": "concurrently -k -n \"BUILD,BROWSER\" -c \"magenta,cyan\" \"npm run watch\" \"npm run serve\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "mjml": "^4.18.0",
    "mkdirp": "^3.0.1",
    "nodemon": "^3.1.11"
  }
}
