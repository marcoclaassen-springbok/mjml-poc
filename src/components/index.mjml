import { BodyComponent } from 'mjml-core'

class MjCustomSection extends BodyComponent {
  // Vertel MJML welke HTML-tag dit moet worden
  render() {
    return this.renderMJML(`
      <mj-section background-color="#f0f0f0">
        <mj-column>
          <mj-text>
            ${this.getContent()}
          </mj-text>
        </mj-column>
      </mj-section>
    `)
  }
}

export default MjCustomSection